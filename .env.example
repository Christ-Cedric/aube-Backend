# Base
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000

# Database
MONGODB_URI=mongodb://localhost:27017/subscription_db
MONGODB_DATABASE=subscription_db

# Redis
REDIS_URL=redis://localhost:6379/1
REDIS_CACHE_TTL_SECONDS=300

# Security (CHANGE THESE IN PRODUCTION)
JWT_SECRET_KEY=generate_a_secure_secret_key_here
JWT_ALGORITHM=HS256

# WebSocket
WS_HEARTBEAT_INTERVAL=30
WS_RECONNECT_DELAY=5

# Background Tasks
EXPIRATION_CHECK_INTERVAL_HOURS=1

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
